{
  "Codexplorer": {
    "Budget": {
      "ContextWindowTokens": 30000,
      "SoftThresholdRatio": 0.8,
      "HardThresholdRatio": 1.0,
      "WindowSize": 5
    },
    "Model": {
      "Name": "openai/gpt-5.4-nano",
      "MaxOutputTokens": 8192,
      "Temperature": 0.0
    },
    "Workspace": {
      "RootDirectory": "./workspace",
      "CloneDepth": 1,
      "MaxRepoSizeMB": 500
    },
    "Agent": {
      "MaxTurns": 50
    },
    "Logging": {
      "SessionLogsDirectory": "./logs/sessions",
      "MinimumLevel": "Information"
    }
  },
  "OpenRouter": {
    "ApiKey": "***redacted***"
  }
}
