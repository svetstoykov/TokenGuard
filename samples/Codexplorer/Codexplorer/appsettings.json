{
  "Codexplorer": {
    "Budget": {
      "ContextWindowTokens": 16000,
      "SoftThresholdRatio": 0.7,
      "HardThresholdRatio": 0.9,
      "WindowSize": 5
    },
    "Model": {
      "Name": "openai/gpt-5.4-nano",
      "MaxOutputTokens": 2048,
      "Temperature": 0.0
    },
    "Workspace": {
      "RootDirectory": "./workspace",
      "CloneDepth": 1,
      "MaxRepoSizeMB": 500
    },
    "Logging": {
      "SessionLogsDirectory": "./logs/sessions",
      "MinimumLevel": "Information"
    }
  },
  "OpenRouter": {
    "ApiKey": "***redacted***"
  }
}
